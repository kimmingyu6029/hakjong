# Required for Gemini-backed recommendations
GEMINI_API_KEY=replace-with-your-real-gemini-key

# Required if you want third parties to use the public API
PUBLIC_API_KEY=replace-with-a-long-random-token

# Optional deployment settings
PORT=3000
HOST=0.0.0.0

# Optional API controls
PUBLIC_API_CORS_ORIGINS=*
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=30
